classDiagram
    direction TB

    %% Componentes Principais
    class project {
        +app/
        +backups/
        +templates/
        +backup_db.py
    }

    class main {
        +run()
    }

    class app_init {
        +create_app()
    }

    class database_models {
        +Eu2016 model
    }

    class modules_core {
        +config.py
        +database.py (db instance)
    }

    class dashboard_routes {
        +view_dashboard()
        +get_history()
        +add_measurement()
        +edit_measurement()
        +inspect_history()
        +delete_measurement()
    }

    class services {
        +history_service.py
    }

    class templates {
        +dashboard.html
        +edit.html
        +inspect.html
        +success.html
    }

    %% Relacionamentos
    project --> app_init : inicializa
    app_init --> modules_core : configura db
    app_init --> dashboard_routes : registra blueprint

    dashboard_routes --> services : chama lógica
    dashboard_routes --> templates : renderiza
    dashboard_routes --> database_models : faz CRUD (ORM)

    services --> database_models : consulta
    database_models --> modules_core : usa db instance

    %% Backup Integration
    dashboard_routes ..> backup_db : aciona backup